# ── AI (Gemini via Vertex AI or direct API key) ───────────────────────────────
# Option A: Vertex AI service account (recommended for production)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"your-sa@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Option B: Direct Gemini API key (simpler, dev/test only)
# GOOGLE_AI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres
# Set DB_SSL=false only for local Postgres without SSL
# DB_SSL=false

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...

# ── Scraping ──────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=AIza...
INSTAGRAM_SESSION_ID=your_session_id
INSTAGRAM_CSRF_TOKEN=your_csrf_token
# Apify fallback when Instagram session cookie is missing
APIFY_API_KEY=apify_api_...

# ── Billing (Razorpay) ────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_secret

# ── Redis (optional — falls back to in-memory if not set) ────────────────────
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your_redis_password

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
# DEV_USER_ID=user-1  # bypasses Clerk auth in development (NODE_ENV=development only)
