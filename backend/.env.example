# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Trust proxy hops (1 = one reverse proxy, e.g. Nginx / Render / Fly.io).
# Required for correct req.ip and rate limiting when behind a load balancer.
TRUST_PROXY=1

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# REQUIRED in production. Server-side secret — never expose to the frontend.
CLERK_SECRET_KEY=sk_live_...
# Publishable key — safe to be public, but also needed by @clerk/express
# middleware to verify JWT headers server-side.
CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Database (Supabase / PostgreSQL) ──────────────────────────────────────────
# REQUIRED in production. Restrict DB access to your app's IP in Supabase settings.
# Use the pooler connection string (port 6543) for serverless / container workloads.
DATABASE_URL=postgresql://postgres.xxx:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Set DB_SSL=false ONLY for a local Postgres instance without SSL configured.
# In production this is always true regardless of this flag.
# DB_SSL=false

# ── CORS / Frontend ───────────────────────────────────────────────────────────
# REQUIRED in production. Only this origin is allowed cross-site.
FRONTEND_URL=https://your-app.com

# ── AI (Gemini via Vertex AI) ─────────────────────────────────────────────────
# Option A: Service account JSON (recommended for production — store in secret manager)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"your-sa@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Option B: Direct Gemini API key (dev/test only — do not use in production)
# GOOGLE_AI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# ── Scraping ──────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=AIza...
INSTAGRAM_SESSION_ID=your_session_id
INSTAGRAM_CSRF_TOKEN=your_csrf_token
# Apify fallback when Instagram session cookie is absent
APIFY_API_KEY=apify_api_...

# ── Billing (Razorpay) ────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Redis (optional — caching disabled if not set) ───────────────────────────
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your_redis_password

# ── Development only ──────────────────────────────────────────────────────────
# DEV_USER_ID=dev-user-1   bypasses Clerk auth when CLERK_SECRET_KEY is absent
