# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Trust proxy hops (1 = one reverse proxy, e.g. Nginx / Render / Fly.io).
# Required for correct req.ip and rate limiting when behind a load balancer.
TRUST_PROXY=1

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# REQUIRED in production. Server-side secret — never expose to the frontend.
CLERK_SECRET_KEY=sk_live_...
# Publishable key — safe to be public, but also needed by @clerk/express
# middleware to verify JWT headers server-side.
CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Database (Supabase / PostgreSQL) ──────────────────────────────────────────
# REQUIRED in production. Restrict DB access to your app's IP in Supabase settings.
# Use the pooler connection string (port 6543) for serverless / container workloads.
DATABASE_URL=postgresql://postgres.xxx:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# SSL behaviour:
#   DB_SSL=false   → disable TLS entirely (ONLY a local Postgres without SSL).
#   DB_CA_CERT     → PEM of the server CA for strict verification (recommended in prod).
#                    Download from Supabase → Settings → Database → SSL configuration.
#   neither set    → TLS on but chain NOT verified (works with the Supabase pooler,
#                    whose CA isn't in Node's trust store). Encrypted, but set
#                    DB_CA_CERT to also verify the certificate.
# DB_SSL=false
# DB_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n"

# ── CORS / Frontend ───────────────────────────────────────────────────────────
# REQUIRED in production. Only this origin is allowed cross-site.
FRONTEND_URL=https://your-app.com

# ── AI (Gemini via Vertex AI) ─────────────────────────────────────────────────
# Option A: Service account JSON (recommended for production — store in secret manager)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"your-sa@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Option B: Direct Gemini API key (dev/test only — do not use in production)
# GOOGLE_AI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# ── Scraping ──────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=AIza...

# Reddit (optional) — without these, Reddit is skipped (anonymous .json is 403-blocked).
# Create a "script" app at https://www.reddit.com/prefs/apps → use the client id/secret.
# REDDIT_USER_AGENT must be unique & descriptive or Reddit blocks you.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=web:influensa:1.0 (by /u/your_reddit_username)

# ── Billing (Razorpay subscriptions) ──────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your_razorpay_secret
# Webhook signing secret — set the SAME value in the Razorpay dashboard webhook config.
# Without it the webhook endpoint returns 503 and plans never activate.
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
# Razorpay Plan IDs — create one Plan per tier+cycle in the Razorpay dashboard, paste IDs here.
RZP_PLAN_PRO_MONTHLY=plan_xxx
RZP_PLAN_PRO_YEARLY=plan_xxx
RZP_PLAN_AGENCY_MONTHLY=plan_xxx
RZP_PLAN_AGENCY_YEARLY=plan_xxx

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated Clerk user IDs allowed into /admin and the admin API.
# Find your ID in the Clerk dashboard (user_xxxxx).
ADMIN_CLERK_IDS=user_xxx,user_yyy

# ── Redis (caching + rate limiting) ──────────────────────────────────────────
# Optional for caching. REQUIRED in any multi-instance deployment for rate
# limiting: in-memory counters are per-process, so without a shared Redis store
# every limit becomes (instance count) × the configured value.
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your_redis_password
#
# Shared Redis-backed rate limiting.
#   prod: ON by default — set RATE_LIMIT_REDIS=false only for a single instance.
#   dev:  OFF by default — set RATE_LIMIT_REDIS=true to test the Redis path locally.
# RATE_LIMIT_REDIS=true

# ── Background scraping ──────────────────────────────────────────────────────────
# Secret for the Cloud Scheduler → POST /api/internal/scrape?tier=fast|slow|all
# trigger. Cloud Scheduler must send it as header: X-CRON-SECRET: <value>.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=replace_with_random_hex
# In-process scrape timers. Prod OFF by default (use Cloud Scheduler). Set true ONLY
# for a single always-on instance. Dev defaults to ON.
# INPROCESS_CRON=true

# ── Development only ──────────────────────────────────────────────────────────
# DEV_USER_ID=dev-user-1   bypasses Clerk auth when CLERK_SECRET_KEY is absent
# DEV_ADMIN=false          set to false to disable the dev admin bypass (default: dev user IS admin when Clerk is off)
