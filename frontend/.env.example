# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# The PUBLISHABLE key is safe for the frontend — it identifies your Clerk instance
# but cannot perform privileged operations. The SECRET key lives in backend/.env only.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── Backend API ───────────────────────────────────────────────────────────────
# Defaults to same origin if not set (works for local dev with Vite proxy)
# VITE_API_URL=http://localhost:3000

# ── NOTE: No other secrets belong here ────────────────────────────────────────
# Database (Supabase), AI (Vertex AI), scrapers (YouTube, Reddit),
# and billing (Razorpay) keys are ALL server-side only → backend/.env
# They are never exposed to the browser or stored in localStorage.
